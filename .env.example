# Vertex AI (recommended on Cloud Run)
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# If you use `gcloud auth application-default login`, set a quota project once (stops ADC UserWarning):
# gcloud auth application-default set-quota-project $GOOGLE_CLOUD_PROJECT

ADK_MODEL=gemini-2.5-flash

# AlloyDB or Cloud SQL / local Postgres — apply sql/migrations/001_init.sql first
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Default user id for multi-tenant demos
DEFAULT_USER_ID=demo-user

# IANA timezone so the schedule agent can resolve "next Wednesday" (e.g. America/Los_Angeles)
USER_TIMEZONE=UTC

# Google Calendar + Tasks (MCP server). Shared credentials; calendar id is calendar-only.
# Pick one auth method:
# 1) Service account — JSON key file or raw JSON; share the calendar with the SA email:
# GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/sa.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_CALENDAR_ID=primary_or_shared_calendar_id
# 2) OAuth user token (refresh token JSON from one-time consent):
# GOOGLE_OAUTH_TOKEN_PATH=/path/to/token.json
# GOOGLE_OAUTH_TOKEN_JSON={"token":"...","refresh_token":"...",...}
# Optional calendar id (default primary for OAuth; SA usually needs explicit id):
# GOOGLE_CALENDAR_ID=primary
# OAuth setup (local): Desktop OAuth client JSON from Google Cloud Console, e.g. secrets/google_oauth_client.json (gitignored):
# GOOGLE_OAUTH_CLIENT_SECRETS_PATH=secrets/google_oauth_client.json
# GOOGLE_OAUTH_TOKEN_PATH=secrets/google_oauth_token.json
# PYTHONPATH=. python -m mcp_servers.oauth_setup
# (Requests Calendar + Tasks scopes; enable both APIs in Google Cloud Console.)

# Google Tasks only — optional task list id (default: first list from the API)
# GOOGLE_TASKS_LIST_ID=MDEx...

# MCP (SSE). The server must be running before adk web, or you get ConnectError.
# From repo root: PYTHONPATH=. MCP_PORT=8765 python -m mcp_servers.app sse
# If you are not running MCP right now, comment out MCP_SSE_URL or set MCP_DISABLED=1
MCP_SSE_URL=http://127.0.0.1:8765/sse
# MCP_DISABLED=1

# Optional: MCP over stdio (local dev). Example args from repo root with PYTHONPATH=.
# MCP_USE_STDIO=1
# MCP_STDIO_ARGS=-m mcp_servers.app stdio
